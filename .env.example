# Fox ESS Cloud — foxesscloud.com → API Management (FOXESS_API_KEY or FOX_API_KEY)
FOXESS_API_KEY=
FOXESS_DEVICE_SN=
# DATALOGGER_SERIAL_NUMBER=
# INVERTER_SERIAL_NUMBER=

# Daikin Onecta OAuth2 — https://developer.cloud.daikineurope.com
DAIKIN_CLIENT_ID=
DAIKIN_CLIENT_SECRET=
DAIKIN_REDIRECT_URI=http://localhost:8080/callback
DAIKIN_TOKEN_FILE=.daikin-tokens.json
# HTTP 429 retries (default 3). Set 0 to fail fast on rate limits.
# DAIKIN_HTTP_429_MAX_RETRIES=3

# Energy providers
OCTOPUS_API_KEY=
OCTOPUS_ACCOUNT_NUMBER=
OCTOPUS_MPAN_1=
OCTOPUS_METER_SN_1=
OCTOPUS_MPAN_2=
OCTOPUS_METER_SN_2=
OCTOPUS_GSP=

# Manual tariff (p/kWh) — Agile example: E-1R-AGILE-24-10-01-<GSP>
MANUAL_TARIFF_IMPORT_PENCE=0
MANUAL_TARIFF_EXPORT_PENCE=0
MANUAL_STANDING_CHARGE_PENCE_PER_DAY=0

# Gas comparison (Insights)
GAS_PRICE_PENCE_PER_KWH=0
GAS_BOILER_EFFICIENCY=0.9
HEAT_PUMP_COP_ESTIMATE=2.8
HEATING_LOAD_SHARE=0.4

# Agile scheduler (Daikin LWT by price) — optional
SCHEDULER_ENABLED=false
OCTOPUS_TARIFF_CODE=
SCHEDULER_CHEAP_THRESHOLD_PENCE=12
SCHEDULER_PEAK_START=16:00
SCHEDULER_PEAK_END=19:00
SCHEDULER_PREHEAT_LWT_BOOST=2

# API server
API_HOST=0.0.0.0
API_PORT=8000
FOXESS_ALERT_LOW_SOC=10
DAIKIN_ALERT_TEMP_DEVIATION=2
# true = read-only for OpenClaw agents; false allows execute endpoints
OPENCLAW_READ_ONLY=true

# Optimization engine (room/DHW targets; export product for LP/analytics)
OPTIMIZATION_ENGINE_ENABLED=true
OPTIMIZATION_PRESET=normal
# Daikin control mode (v10): passive = service never writes to Daikin, treats it
# as a fixed thermal load (firmware autonomous). active = legacy v9 control path.
# Flip via PUT /api/v1/settings/DAIKIN_CONTROL_MODE without restart.
DAIKIN_CONTROL_MODE=passive
# Legacy / optional — may be ignored depending on build; see CHANGELOG if unset has no effect
# TARGET_PRICE_PENCE=12.0
TARGET_ROOM_TEMP_MIN_C=20.0
TARGET_ROOM_TEMP_MAX_C=23.0
TARGET_DHW_TEMP_MIN_NORMAL_C=45.0
TARGET_DHW_TEMP_MIN_GUESTS_C=48.0
TARGET_DHW_TEMP_MAX_C=65.0
# LP building model: unoccupied indoor floor (°C) — see docs/phase2-epic-tasks.md (#21)
# LP_OVERNIGHT_COMFORT_FLOOR_C=18.0

# DHW plunge-pricing policy (issue #50):
#   DHW_TEMP_COMFORT_C is the tank ceiling for positive-price slots (normal comfort target).
#   DHW_TEMP_MAX_C is the plunge-only ceiling (LP allows tank > 48 °C only when price < 0).
# DHW_TEMP_COMFORT_C=48.0
# DHW_TEMP_MAX_C=65.0

# DEPRECATED: Daikin Onecta firmware runs the weekly thermal-shock cycle autonomously
# (Sunday ~11:00 local). These knobs are unused by the LP / dispatch as of PR #50 and
# will be removed in a follow-up — leaving them in an existing .env is safe.
# DHW_LEGIONELLA_TEMP_C=60
# DHW_LEGIONELLA_DAY=6
# DHW_LEGIONELLA_HOUR_START=11
# DHW_LEGIONELLA_HOUR_END=13

# Anti-sauna LWT cap (issue #50): reduce radiator overshoot during max_heat to +5 °C.
# OPTIMIZATION_LWT_OFFSET_MAX=5
# LWT_OFFSET_MAX=5

# Grid-charge rate matched to Fox nameplate (issue #50): 6 kW inverter AC limit.
# MAX_INVERTER_KW=6.0

# Morning-shower DHW floor disabled by default — family showers in the evening.
# Set to "07:00" (or similar HH:MM) to re-enable a morning DHW demand floor.
# LP_SHOWER_MORNING_LOCAL=

# MPC re-solve hours (local). Default now includes 21:00 for late-evening rates refresh.
# LP_MPC_HOURS=6,12,21

# Nightly plan push: UTC (anchored to Daikin quota rollover at 00:00 UTC).
# LP_PLAN_PUSH_HOUR=0
# LP_PLAN_PUSH_MINUTE=5

# LP COP pre-processing (#29): 0 = outdoor-only COP curve (legacy). >0 penalises high LWT−T_out lift.
# LP_COP_LIFT_PENALTY_PER_KELVIN=0
# LP_COP_LIFT_REFERENCE_DELTA_K=25
# LP_COP_LIFT_MIN_MULTIPLIER=0.5
# LP_COP_DHW_LIFT_SUPPLY_C=45
# LP_COP_SPACE_LWT_CEILING_C=50

# Heat pump electrical cap in MILP (kW)
# DAIKIN_MAX_HP_KW=2.0
MIN_SOC_RESERVE_PERCENT=15.0
OCTOPUS_EXPORT_TARIFF_CODE=

# ── API Quota & Cache ────────────────────────────────────────────────────────
DAIKIN_DAILY_BUDGET=180
DAIKIN_DEVICES_CACHE_TTL_SECONDS=1800
DAIKIN_FORCE_REFRESH_MIN_INTERVAL_SECONDS=1800
DAIKIN_SLOT_TRANSITION_WINDOW_SECONDS=300

FOX_DAILY_BUDGET=1200
FOX_REALTIME_CACHE_TTL_SECONDS=300
FOX_FORCE_REFRESH_MIN_INTERVAL_SECONDS=60

# OpenClaw Gateway — all user notifications POST here (see docs/RUNBOOK.md)
# Legacy ALERT_OPENCLAW_URL / ALERT_CHANNEL are not used; remove if still in an old .env.
OPENCLAW_NOTIFY_ENABLED=true
OPENCLAW_NOTIFY_CHANNEL=telegram
OPENCLAW_NOTIFY_TARGET=
OPENCLAW_HOOKS_URL=http://127.0.0.1:18789/hooks/agent
OPENCLAW_HOOKS_TOKEN=
OPENCLAW_HOOKS_TIMEOUT_SECONDS=30
OPENCLAW_HOOKS_AGENT_ID=
OPENCLAW_INTERNAL_API_BASE_URL=http://127.0.0.1:8000
# Daikin schedule windows: minimum half-hour slots (2 = 1 hour minimum)
DAIKIN_MIN_WINDOW_SLOTS=2
# Plan approval / regen (bulletproof + planner)
PLAN_AUTO_APPROVE=false
PLAN_REGEN_COOLDOWN_SECONDS=300
# simulation | operational
OPERATION_MODE=simulation

# ── Optional: bulletproof engine + weather + V9 LP (full local dev) ─────────
# USE_BULLETPROOF_ENGINE=true
# DB_PATH=energy_state.db
# TZ=Europe/London
# BULLETPROOF_TIMEZONE=Europe/London
# HEARTBEAT_INTERVAL_SECONDS=120
# OCTOPUS_FETCH_HOUR=16
# OCTOPUS_FETCH_MINUTE=5
# DAILY_BRIEF_HOUR=8
# DAILY_BRIEF_MINUTE=0
# ENERGY_STRATEGY_MODE=savings_first
# OPTIMIZER_BACKEND=lp
# WEATHER_LAT=51.5
# WEATHER_LON=-0.26
# LP_SOLVER=highs
# LP_HIGHS_TIME_LIMIT_SECONDS=30
# (See prior commits or docs for full LP_* / FOX_LP_* / building model vars.)
