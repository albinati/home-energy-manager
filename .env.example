# Fox ESS Cloud
# Option A: Official Open API key / private token (User Profile → API Management on foxesscloud.com)
#   Set FOX_API_KEY to your Open API key from the Fox ESS portal. FOXESS_API_KEY is also accepted for compatibility.
FOXESS_API_KEY=
# Device serial for most Open API calls (realtime, history, work mode): inverter plate SN
FOXESS_DEVICE_SN=
INVERTER_SERIAL_NUMBER=
# Datalogger / WiFi module serial (informational; device list returns it as moduleSN).
DATALOGGER_SERIAL_NUMBER=
# Rare: set only if Fox Open API scheduler endpoints require module SN in `deviceSN` instead of inverter.
# FOXESS_SCHEDULER_SN=

# Daikin Onecta OAuth2 (docs: https://developer.cloud.daikineurope.com/docs/84e709f1-9d33-47e1-a93c-7f5cb8b8f12b)
# Register at: developer.cloud.daikineurope.com (same email as Onecta app)
# Use --setup mode for first-time registration (see README)
DAIKIN_CLIENT_ID=
DAIKIN_CLIENT_SECRET=
DAIKIN_REDIRECT_URI=http://localhost:8080/callback
# Access tokens refresh automatically (refresh_token grant) before expiry on each API call.
# Point this at a persistent path in production (docker-compose sets /app/data/.daikin-tokens.json).
DAIKIN_TOKEN_FILE=.daikin-tokens.json
# Seconds before access-token expiry to call the refresh_token grant (default 600). Heartbeat prefetches too.
# DAIKIN_ACCESS_REFRESH_LEEWAY_SECONDS=600
# Minimum seconds between refresh_token HTTP calls (default 120) to avoid bursts against OIDC / daily caps.
# DAIKIN_TOKEN_REFRESH_MIN_INTERVAL_SECONDS=120
# Daikin Onecta HTTP 429 retries (default 3); backs off using Retry-After when the API sends it.
# DAIKIN_HTTP_429_MAX_RETRIES=3
# Call volume: each bulletproof heartbeat hits Onecta at least once (e.g. GET /gateway-devices). Raise
# HEARTBEAT_INTERVAL_SECONDS (default 120) if you need fewer polls; check Fox/Octopus limits separately.
# Optional: if docs list different auth/token URLs (e.g. via developer portal), set them here
# DAIKIN_AUTH_URL=
# DAIKIN_TOKEN_URL=

# Alerts: stdout always. To also send to OpenClaw (webchat, Telegram, etc.):
ALERT_OPENCLAW_URL=http://127.0.0.1:18789/api/send
ALERT_CHANNEL=webchat

# Energy providers (for tariff tracking and cost analysis)
# Octopus Energy — get your API key from https://octopus.energy/dashboard/developer/
OCTOPUS_API_KEY=
OCTOPUS_ACCOUNT_NUMBER=

# British Gas — API access (if available)
BRITISH_GAS_API_KEY=

# Manual tariff (p/kWh) — fallback when no provider; also used in some analytics with Octopus
# Example Agile Octopus import: product AGILE-24-10-01 → full code often E-1R-AGILE-24-10-01-<GSP>
# Standing charge from bill (p/day incl VAT), e.g. 62.22
MANUAL_TARIFF_IMPORT_PENCE=0
MANUAL_TARIFF_EXPORT_PENCE=0
MANUAL_STANDING_CHARGE_PENCE_PER_DAY=0

# Gas comparison (solar + heat pump vs gas): set to see "equivalent gas cost" on Insights
GAS_PRICE_PENCE_PER_KWH=0
GAS_BOILER_EFFICIENCY=0.9
HEAT_PUMP_COP_ESTIMATE=2.8
HEATING_LOAD_SHARE=0.4

# Heating analytics (Insights): degree-days and spend-by-temperature need weather. Optional.
# WEATHER_LAT=52.52
# WEATHER_LON=-1.47
# WEATHER_DEGREE_DAY_BASE_C=15.5

# Agile scheduler (Daikin LWT by Octopus price) — optional
SCHEDULER_ENABLED=false
OCTOPUS_TARIFF_CODE=
SCHEDULER_CHEAP_THRESHOLD_PENCE=12
SCHEDULER_PEAK_START=16:00
SCHEDULER_PEAK_END=19:00
SCHEDULER_PREHEAT_LWT_BOOST=2

# API server settings
API_HOST=0.0.0.0
API_PORT=8000
# OpenClaw: point the skill at this server by setting HOME_ENERGY_API_URL=http://THIS_HOST:8000 in OpenClaw config
# When true (default), OpenClaw can only read status and recommend; POST execute returns 403. Set false to allow execution.
OPENCLAW_READ_ONLY=true

# Thresholds
FOXESS_ALERT_LOW_SOC=10
DAIKIN_ALERT_TEMP_DEVIATION=2

# Bulletproof engine (SQLite + Fox Scheduler V3 + 2-min heartbeat) — default on
USE_BULLETPROOF_ENGINE=true
DB_PATH=energy_state.db
HEARTBEAT_INTERVAL_SECONDS=120
SVT_RATE_PENCE=24.50
OPTIMIZATION_PEAK_THRESHOLD_PENCE=25
OCTOPUS_FETCH_HOUR=16
OCTOPUS_FETCH_MINUTE=5
DAILY_BRIEF_HOUR=8
DAILY_BRIEF_MINUTE=0
BULLETPROOF_TIMEZONE=Europe/London
# Savings-first: peak grid export (Fox ForceDischarge) only if preset travel/away and SoC high enough.
# savings_first — allow that; strict_savings — never schedule peak export discharge.
ENERGY_STRATEGY_MODE=savings_first
EXPORT_DISCHARGE_MIN_SOC_PERCENT=95
EXPORT_DISCHARGE_FLOOR_SOC_PERCENT=15
# Preset for bulletproof export rule + legacy solver: normal | travel | away | guests | boost
OPTIMIZATION_PRESET=normal
WEATHER_LAT=51.4927
WEATHER_LON=-0.2628
WEATHER_COLD_THRESHOLD_C=5
WEATHER_MILD_THRESHOLD_C=15
WEATHER_FROST_THRESHOLD_C=2
BATTERY_CAPACITY_KWH=10
FOX_FORCE_CHARGE_MAX_PWR=6000
FOX_FORCE_CHARGE_NORMAL_PWR=3000
LWT_OFFSET_MAX=10
LWT_OFFSET_MIN=-5
PV_CAPACITY_KWP=4.5
PV_SYSTEM_EFFICIENCY=0.85

# V9 PuLP MILP planner (default: lp). Set heuristic to use legacy price-quantile classifier only.
# OPTIMIZER_BACKEND=lp
# LP_HORIZON_HOURS=36
# EXPORT_RATE_PENCE=15
# BATTERY_RT_EFFICIENCY=0.92
# MAX_INVERTER_KW=3
# Solver: HiGHS (default, fast) or CBC (LP_SOLVER=cbc):
# LP_SOLVER=highs
# LP_HIGHS_TIME_LIMIT_SECONDS=30
# LP_CBC_TIME_LIMIT_SECONDS=30
# Inverter stress cost (piecewise-linear quadratic approx; 0=off, 0.10-0.20 recommended):
# LP_INVERTER_STRESS_COST_PENCE=0.12
# LP_INVERTER_STRESS_SEGMENTS=8
# HP anti-cycling: minimum consecutive ON slots when heat pump starts:
# LP_HP_MIN_ON_SLOTS=2
# Terminal SoC hard floor (kWh); 0 = soft (soc_end >= soc_init):
# LP_SOC_FINAL_KWH=2.0
# MPC intra-day re-optimise cron hours (local, comma-separated):
# LP_MPC_HOURS=6,12
# Per-slot load profile window (execution_log rows; falls back to flat mean when cold):
# LP_LOAD_PROFILE_SLOTS=2016
# Less "penny chasing" / fewer hardware switches:
# LP_BATTERY_TV_PENALTY_PENCE_PER_KWH_DELTA=0.5
# LP_HP_POWER_TV_PENALTY_PENCE_PER_KWH_DELTA=1.0
# LP_IMPORT_TV_PENALTY_PENCE_PER_KWH_DELTA=0.25
# LP_PRICE_QUANTIZE_PENCE=2
# LP_CYCLE_PENALTY_PENCE_PER_KWH=0.15
# Merge LP dispatch gaps so Fox stays in ForceCharge (0 = off):
# FOX_LP_BRIDGE_GAP_SLOTS=8
# FOX_LP_BRIDGE_MAX_PRICE_PENCE=0
# BUILDING_UA_W_PER_K=180
# BUILDING_THERMAL_MASS_KWH_PER_K=8
# DHW_TANK_UA_W_PER_K=2.5
# DAIKIN_COP_CURVE=-7:1.8,2:2.6,7:3.1,12:3.6,20:4.2

# ── API Quota & Cache ────────────────────────────────────────────────────────
# Daikin Onecta soft daily budget (real limit ≈200; default 180 = 10% headroom)
# DAIKIN_DAILY_BUDGET=180
# Time-to-live for cached device data (seconds); 1800 = 30 min
# DAIKIN_DEVICES_CACHE_TTL_SECONDS=1800
# Minimum gap between user-initiated force-refresh calls (seconds)
# DAIKIN_FORCE_REFRESH_MIN_INTERVAL_SECONDS=1800
# Width of the Octopus pre-slot window that allows auto-refresh (seconds before :30/:00)
# DAIKIN_SLOT_TRANSITION_WINDOW_SECONDS=300

# Fox ESS soft daily budget (real limit ≈1440; default 1200 = 15% headroom)
# FOX_DAILY_BUDGET=1200
# Realtime data TTL raised from 30s to 300s (5 min) to match heartbeat interval
# FOX_REALTIME_CACHE_TTL_SECONDS=300
# Minimum gap between user-initiated force-refresh calls (seconds)
# FOX_FORCE_REFRESH_MIN_INTERVAL_SECONDS=60
