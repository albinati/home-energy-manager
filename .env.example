# Fox ESS Cloud API
# Get from: foxesscloud.com → My Account → API Management
FOXESS_API_KEY=your_api_key_here
FOXESS_DEVICE_SN=your_device_serial_number

# Daikin Onecta OAuth2
# Register at: developer.cloud.daikineurope.com
DAIKIN_CLIENT_ID=your_client_id
DAIKIN_CLIENT_SECRET=your_client_secret
DAIKIN_REDIRECT_URI=http://localhost:8080/callback
# Token file is written by the auth flow — do not commit
DAIKIN_TOKEN_FILE=.daikin-tokens.json

# Optional: WhatsApp alert number (E.164 format)
ALERT_WHATSAPP_NUMBER=+447386796373

# Optional: minimum battery SoC before alerting (default: 10%)
FOXESS_ALERT_LOW_SOC=10
# Optional: temperature deviation before alerting (default: 2°C)
DAIKIN_ALERT_TEMP_DEVIATION=2
