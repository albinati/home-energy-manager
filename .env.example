# Fox ESS Cloud
# Option A: Official Open API key (User Profile → API Management on foxesscloud.com)
#   If you don't see API Management, contact Fox ESS support or use Option B.
FOXESS_API_KEY=

# Option B: Username/password (works for all endUser accounts — unofficial but stable)
FOXESS_USERNAME=
FOXESS_PASSWORD=

# Your inverter serial number (foxesscloud.com → Devices)
FOXESS_DEVICE_SN=

# Daikin Onecta OAuth2
# Register at: developer.cloud.daikineurope.com (same email as Onecta app)
# IMPORTANT: In your developer app, add redirect URI: http://localhost:8080/callback
DAIKIN_CLIENT_ID=
DAIKIN_CLIENT_SECRET=
DAIKIN_REDIRECT_URI=http://localhost:8080/callback
DAIKIN_TOKEN_FILE=.daikin-tokens.json

# Optional: WhatsApp alerts
ALERT_WHATSAPP_NUMBER=+447386796373

# Thresholds
FOXESS_ALERT_LOW_SOC=10
DAIKIN_ALERT_TEMP_DEVIATION=2
