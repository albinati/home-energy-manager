#!/usr/bin/env bash
# Start the Home Energy Manager MCP server (stdio). Same Python rules as ./bin/serve.
#
# Usage: ./bin/mcp
# OpenClaw / Cursor: command = this script, cwd = project root, env from .env.
#
set -e
ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$ROOT"
export PYTHONPATH="$ROOT"
# shellcheck source=bin/lib.sh
. "$(dirname "$0")/lib.sh"
exec "$(hem_python "$ROOT")" -m src.mcp_server "$@"
