#!/usr/bin/env bash
# Start the Home Energy Manager API server as a background daemon.
# Keeps the dashboard and OpenClaw API available; data is updated when clients call the API.
# Logs to daemon.log; PID in .home-energy-manager.pid.
#
# Usage: ./bin/start [--port PORT]
# Stop:  ./bin/stop
#
set -e
ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$ROOT"
export PYTHONPATH="$ROOT"
# shellcheck source=bin/lib.sh
. "$(dirname "$0")/lib.sh"
exec "$(hem_python "$ROOT")" -m src.cli daemon start "$@"
