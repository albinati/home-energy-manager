#!/usr/bin/env bash
# Show Home Energy Manager daemon status (running or not, PID, API and OpenClaw URLs).
#
# Usage: ./bin/status
#
set -e
ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$ROOT"
export PYTHONPATH="$ROOT"
# shellcheck source=bin/lib.sh
. "$(dirname "$0")/lib.sh"
exec "$(hem_python "$ROOT")" -m src.cli daemon status "$@"
